---
export interface Props {
  href: string;
  title: string;
  description?: string;
  cover?: string;
  tag?: string;
  meta?: string;
}
const { href, title, description, cover, tag, meta } = Astro.props;
---

<a href={href} class="card">
  <div class="thumb">
    {cover
      ? <img src={cover} alt={title} loading="lazy" />
      : <div class="thumb-fallback"><span>🦎</span></div>}
    {tag && <span class="card-tag">{tag}</span>}
  </div>
  <div class="body">
    <h3>{title}</h3>
    {description && <p class="muted">{description}</p>}
    {meta && <span class="meta">{meta}</span>}
  </div>
</a>

<style>
  .card {
    display: flex; flex-direction: column;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); overflow: hidden;
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
  }
  .card:hover { transform: translateY(-4px); border-color: var(--brand); box-shadow: var(--shadow); }
  .thumb { position: relative; aspect-ratio: 16 / 10; background: var(--surface-2); overflow: hidden; }
  .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
  .card:hover .thumb img { transform: scale(1.05); }
  .thumb-fallback { display: grid; place-items: center; height: 100%; font-size: 46px; opacity: .35; }
  .card-tag {
    position: absolute; inset-block-start: 12px; inset-inline-start: 12px;
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    backdrop-filter: blur(6px); color: var(--brand);
    font-size: 12.5px; font-weight: 500; padding: 4px 12px; border-radius: 999px;
    border: 1px solid rgba(63,174,109,.3);
  }
  .body { padding: 18px 18px 20px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .body h3 { font-size: 18px; }
  .body p { font-size: 14.5px; line-height: 1.7; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .meta { margin-top: auto; font-size: 13px; color: var(--text-muted); padding-top: 4px; }
</style>
