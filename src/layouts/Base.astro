---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/images/og-default.jpg',
  type = 'website',
  publishedTime,
  noindex = false,
} = Astro.props;

const site = 'اگزوتیک با مهدیار';
const fullTitle = title === site ? title : `${title} | ${site}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const isHome = Astro.url.pathname === '/';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'دکتر مهدیار رمزگویان',
  jobTitle: 'دامپزشک حیوانات اگزوتیک',
  description: 'دامپزشک باغ پرندگان تهران، متخصص طب حیوانات اگزوتیک، خزندگان و پرندگان زینتی.',
  url: Astro.site?.href,
  image: new URL('/images/photos/macaw-1.jpg', Astro.site).href,
  sameAs: ['https://instagram.com/exoticsbymahdiyar'],
  worksFor: {
    '@type': 'Organization',
    name: 'باغ پرندگان تهران',
    address: { '@type': 'PostalAddress', addressLocality: 'تهران', addressCountry: 'IR' },
  },
  knowsAbout: ['طب حیوانات اگزوتیک', 'خزندگان', 'هرپتولوژی', 'طب پرندگان', 'نگهداری بردد دراگون', 'نگهداری مار', 'نگهداری طوطی'],
  knowsLanguage: ['fa', 'en'],
};

// WebSite schema only on the homepage (helps brand/sitelinks understanding; avoids duplicate emission)
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site,
  alternateName: 'دامپزشکی حیوانات اگزوتیک با مهدیار',
  url: Astro.site?.href,
  inLanguage: 'fa-IR',
  description: 'مرجع فارسی دامپزشکی حیوانات اگزوتیک؛ مقالات علمی، اخبار روز و کتابخانه‌ی تخصصی خزندگان، پرندگان و پستانداران اگزوتیک.',
  publisher: { '@type': 'Person', name: 'دکتر مهدیار رمزگویان' },
};
---

<!doctype html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0f1512" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/Vazirmatn-Regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-50P36FZK7P"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-50P36FZK7P');
    </script>

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:site_name" content={site} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" type="application/rss+xml" title={site} href="/rss.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
      if (!mq.matches) {
        // Never hide an entire long section: its visible intersection can stay below
        // the observer threshold forever (the news archive is a good example).
        const targets = document.querySelectorAll('main .hero-inner, main .section-head, main .card');
        targets.forEach((el) => el.setAttribute('data-reveal', ''));
        // stagger cards within each grid
        document.querySelectorAll('main .grid').forEach((grid) => {
          Array.from(grid.children).forEach((card, i) => {
            const d = Math.min(i % 3, 3);
            if (d) card.classList.add('d' + d);
          });
        });
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
          });
        }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
        targets.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
