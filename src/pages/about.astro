---
import { getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const about = await getEntry('pages', 'about');
const { title, role, specialties, education } = about.data;
const { Content } = await render(about);
---
<Base title="درباره من" description="دکتر مهدیار رمزگویان، دامپزشک باغ پرندگان تهران و متخصص حیوانات اگزوتیک؛ معرفی، تخصص‌ها و مسیر حرفه‌ای.">
  <section class="section container about">
    <span class="eyebrow">درباره من</span>
    <h1>{title}</h1>
    {role && <p class="role muted">{role}</p>}

    {specialties.length > 0 && (
      <div class="chips">
        {specialties.map((s) => <span class="tag">{s}</span>)}
      </div>
    )}

    <div class="prose" style="max-width:760px;margin-top:26px">
      <Content />
    </div>

    {education.length > 0 && (
      <div class="edu">
        <h2>تحصیلات و دوره‌ها</h2>
        <ul class="muted">
          {education.map((e) => <li>{e}</li>)}
        </ul>
      </div>
    )}

    <div class="about-cta">
      <a href="/visit" class="btn">ویزیت آنلاین</a>
      <a href="https://instagram.com/exoticsbymahdiyar" target="_blank" rel="noopener" class="btn btn-ghost">اینستاگرام</a>
    </div>
  </section>
</Base>

<style>
  .role { font-size: 1.05rem; margin-top: 6px; }
  .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; }
  .edu { margin-top: 40px; max-width: 760px; }
  .edu h2 { font-size: 1.4rem; margin-bottom: 14px; }
  .edu ul { padding-inline-start: 1.3em; line-height: 2; }
  .edu li { margin-bottom: 4px; }
  .about-cta { display: flex; gap: 12px; margin-top: 34px; flex-wrap: wrap; }
</style>
