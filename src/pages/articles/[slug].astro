---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Card from '../../components/Card.astro';

export async function getStaticPaths() {
  const items = await getCollection('articles', ({ data }) => !data.draft);
  return items.map((a) => ({ params: { slug: a.id }, props: { article: a, allArticles: items } }));
}

const { article, allArticles } = Astro.props;
const { Content } = await render(article);
const d = article.data;
const fa = (x: Date) => x.toLocaleDateString('fa-IR', { year: 'numeric', month: 'long', day: 'numeric' });

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  headline: d.title,
  description: d.description,
  datePublished: d.pubDate.toISOString(),
  dateModified: (d.updatedDate ?? d.pubDate).toISOString(),
  author: { '@type': 'Person', name: d.author, url: new URL('/about', Astro.site).href },
  publisher: { '@type': 'Person', name: 'دکتر مهدیار رمزگویان', url: new URL('/about', Astro.site).href },
  inLanguage: 'fa-IR',
  mainEntityOfPage: canonicalUrl,
  ...(d.cover && { image: new URL(d.cover, Astro.site).href }),
  ...(d.tags.length > 0 && { keywords: d.tags.join('، ') }),
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'خانه', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'مقالات', item: new URL('/articles', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: d.title, item: canonicalUrl },
  ],
};
const related = allArticles
  .filter((a) => a.id !== article.id && a.data.category === d.category)
  .sort((a, b) => {
    const score = (item) => item.data.tags.filter((tag) => d.tags.includes(tag)).length;
    return score(b) - score(a) || b.data.pubDate.getTime() - a.data.pubDate.getTime();
  })
  .slice(0, 3);
---
<Base title={d.title} description={d.description} image={d.cover} type="article" publishedTime={d.pubDate.toISOString()}>
  <article class="container post">
    <nav class="crumb muted"><a href="/">خانه</a> / <a href="/articles">مقالات</a></nav>
    <span class="tag">{d.category}</span>
    <h1>{d.title}</h1>
    <div class="post-meta muted">
      <span>نویسنده: <a href="/about" rel="author">{d.author}</a></span><span>•</span><span>انتشار: {fa(d.pubDate)}</span>
      {d.updatedDate && <><span>•</span><span>بازبینی: {fa(d.updatedDate)}</span></>}
    </div>
    {d.cover && <img class="cover" src={d.cover} alt={d.title} loading="eager" decoding="async" fetchpriority="high" />}
    <div class="prose"><Content /></div>

    {d.sources.length > 0 && (
      <div class="sources">
        <h3>منابع</h3>
        <ol>{d.sources.map((s) => (
          <li>{s.url ? <a href={s.url} target="_blank" rel="noopener">{s.label}</a> : s.label}</li>
        ))}</ol>
      </div>
    )}

    {d.tags.length > 0 && <div class="tags">{d.tags.map((t) => <span class="tag">#{t}</span>)}</div>}

    {related.length > 0 && (
      <div class="related">
        <h3>مقالات مرتبط</h3>
        <div class="grid grid-3">
          {related.map((a) => (
            <Card href={`/articles/${a.id}`} title={a.data.title} description={a.data.description} cover={a.data.cover} tag={a.data.category} />
          ))}
        </div>
      </div>
    )}
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
</Base>
<style>
  .post { max-width: 760px; padding-block: 40px 80px; }
  .crumb { font-size: 14px; margin-bottom: 18px; }
  .crumb a:hover { color: var(--brand); }
  .post h1 { margin-block: 14px 12px; }
  .post-meta { display: flex; gap: 10px; font-size: 14.5px; margin-bottom: 26px; }
  .post-meta { flex-wrap: wrap; }
  .post-meta a { color: var(--brand); font-weight: 700; }
  .cover { width: 100%; border-radius: var(--radius); margin-bottom: 30px; aspect-ratio: 16/9; object-fit: cover; }
  .sources { margin-top: 44px; padding: 22px 24px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); }
  .sources h3 { font-size: 18px; margin-bottom: 12px; }
  .sources ol { padding-inline-start: 1.3em; }
  .sources li { margin-bottom: 8px; font-size: 15px; }
  .sources a { color: var(--brand); }
  .tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 30px; }
  .related { margin-top: 56px; padding-top: 40px; border-top: 1px solid var(--border); }
  .related h3 { font-size: 20px; margin-bottom: 20px; }
</style>
