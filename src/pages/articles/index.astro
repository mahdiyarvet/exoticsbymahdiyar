---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Card from '../../components/Card.astro';

const fa = (d: Date) => d.toLocaleDateString('fa-IR', { year: 'numeric', month: 'long', day: 'numeric' });
const items = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const cats = [...new Set(items.map((i) => i.data.category))];

const listSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'مقالات دامپزشکی اگزوتیک',
  url: new URL('/articles', Astro.site).href,
  isPartOf: { '@type': 'WebSite', name: 'اگزوتیک با مهدیار', url: Astro.site?.href },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: items.slice(0, 20).map((a, i) => ({
      '@type': 'ListItem', position: i + 1,
      url: new URL(`/articles/${a.id}`, Astro.site).href, name: a.data.title,
    })),
  },
};
---
<Base title="مقالات" description="مجموعه مقالات علمی و آموزشی دامپزشکی حیوانات اگزوتیک؛ خزندگان، پرندگان و پستانداران، نگارش دکتر مهدیار رمزگویان.">
  <script type="application/ld+json" set:html={JSON.stringify(listSchema)} />
  <section class="section container">
    <span class="eyebrow">مقالات</span>
    <h1>مقالات دامپزشکی اگزوتیک</h1>
    <p class="muted" style="max-width:60ch;margin-top:8px">راهنماها و مقالات تخصصی درباره‌ی سلامت، تغذیه و نگهداری حیوانات اگزوتیک.</p>
    {cats.length > 1 && <div class="filters">{cats.map((c) => <span class="tag">{c}</span>)}</div>}
    {items.length === 0
      ? <p class="empty muted">هنوز مقاله‌ای منتشر نشده. به‌زودی…</p>
      : <div class="grid grid-3" style="margin-top:28px">{items.map((a) => (
          <Card href={`/articles/${a.id}`} title={a.data.title} description={a.data.description}
            cover={a.data.cover} tag={a.data.category} meta={fa(a.data.pubDate)} />))}</div>}
  </section>
</Base>
<style>.filters{display:flex;gap:8px;flex-wrap:wrap;margin-top:20px}.empty{padding:60px 0;text-align:center}</style>
