---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { getContentTopic, getNewsCover, isPhotographicCover, normalizeContentTitle } from '../contentImages';

const fa = (d: Date) => d.toLocaleDateString('fa-IR', { year: 'numeric', month: 'long', day: 'numeric' });
const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const news = (await getCollection('news', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const books = await getCollection('books', ({ data }) => !data.draft);
const guides = articles.slice(0, 5);
const featuredBook = books[0];

const compactRailTitle = (title: string) => {
  const summaries: Array<[RegExp, string]> = [
    [/مارمولک.*سرطان|سرطان.*مارمولک/i, 'مارمولک‌ها و سرنخ‌های سرطان'],
    [/قناری/i, 'قفس و تغذیه سالم قناری'],
    [/لاک[‌\s-]?پشت.*(?:40|۴۰)/i, 'لاک‌پشت ۴۰ کیلویی در جست‌وجوی خانه'],
    [/آکسولوتل/i, 'آکواریوم مناسب آکسولوتل'],
    [/گونه.*آفتاب[‌\s-]?پرست|آفتاب[‌\s-]?پرست.*گونه/i, 'کشف گونه‌های جدید آفتاب‌پرست'],
    [/ماکائو/i, 'راهنمای نگهداری ماکائو'],
    [/کاکادو/i, 'راهنمای نگهداری کاکادو'],
    [/کاسکو|طوطی خاکستری/i, 'راهنمای نگهداری کاسکو'],
    [/مار.*(?:میلک|کینگ)|(?:میلک|کینگ).*مار/i, 'نگهداری مار میلک و کینگ'],
    [/گکو/i, 'تازه‌های دنیای گکوها'],
    [/خرگوش/i, 'مراقبت بهتر از خرگوش‌ها'],
    [/قورباغه/i, 'شرایط مناسب نگهداری قورباغه'],
    [/لاک[‌\s-]?پشت/i, 'خبرهای تازه درباره لاک‌پشت‌ها'],
  ];
  const matched = summaries.find(([pattern]) => pattern.test(title));
  if (matched) return matched[1];

  const clean = title.replace(/^نگهداری\s+/i, '').replace(/\s+/g, ' ').trim();
  if (clean.length <= 38) return clean;
  const shortened = clean.slice(0, 38).replace(/\s+\S*$/, '').trim();
  return `${shortened}…`;
};

type RailItem = {
  href: string;
  title: string;
  pubDate: Date;
  cover: string;
  kind: 'خبر' | 'راهنما';
};

const usedTopics = new Set<string>();
const usedCovers = new Set<string>();
const usedNewsTitles = new Set<string>();
const selectedNews: RailItem[] = [];

for (const item of news) {
  const titleKey = normalizeContentTitle(item.data.title);
  const topic = getContentTopic(item.data.title, item.data.cover);
  if (usedNewsTitles.has(titleKey) || usedTopics.has(topic)) continue;

  const cover = getNewsCover(item, usedCovers);
  selectedNews.push({ href: `/news/${item.id}`, title: item.data.title, pubDate: item.data.pubDate, cover, kind: 'خبر' });
  usedNewsTitles.add(titleKey);
  usedTopics.add(topic);
  if (selectedNews.length === 3) break;
}

const selectedArticles: RailItem[] = [];
const usedArticleCategories = new Set<string>();
for (const item of articles) {
  if (!isPhotographicCover(item.data.cover)) continue;
  const topic = getContentTopic(item.data.title, item.data.cover);
  if (usedTopics.has(topic) || usedArticleCategories.has(item.data.category)) continue;

  selectedArticles.push({ href: `/articles/${item.id}`, title: item.data.title, pubDate: item.data.pubDate, cover: item.data.cover, kind: 'راهنما' });
  usedTopics.add(topic);
  usedCovers.add(item.data.cover);
  usedArticleCategories.add(item.data.category);
  if (selectedArticles.length === 2) break;
}

const railItems = [selectedNews[0], selectedArticles[0], selectedNews[1], selectedArticles[1], selectedNews[2]]
  .filter((item): item is RailItem => Boolean(item));
---

<Base title="اگزوتیک با مهدیار" description="مرجع فارسی نگهداری و دامپزشکی حیوانات اگزوتیک؛ راهنمای خزندگان، پرندگان، پستانداران کوچک، اخبار، کتابخانه و ویزیت آنلاین با دکتر مهدیار رمزگویان.">
  <div class="magazine-shell container">
    <section class="editorial-grid" aria-labelledby="hero-title">
      <aside class="news-rail">
        <div class="rail-title"><span>اخبار و دانستنی‌ها</span><i></i></div>
        <div class="rail-list">
          {railItems.map((item) => (
            <a href={item.href} class="rail-item" title={item.title}>
              <img src={item.cover} alt={item.title} loading="lazy" width="120" height="90" />
              <span><b>{compactRailTitle(item.title)}</b><small><em>{item.kind}</em>{fa(item.pubDate)}</small></span>
            </a>
          ))}
        </div>
        <a href="/news" class="text-link">مشاهده همه اخبار <span>←</span></a>
      </aside>

      <div class="hero-collage">
        <div class="hero-animal hero-iguana"><img src="/images/photos/iguana-3.jpg" alt="نمای کامل صورت ایگوانا" width="900" height="900" fetchpriority="high" /></div>
        <div class="hero-copy">
          <span class="kicker">دانش، تجربه و احترام به طبیعت</span>
          <h1 id="hero-title">زندگی بهتر<br /><span>برای حیوانات اگزوتیک</span></h1>
          <p>هر موجود، دنیایی شگفت‌انگیز دارد. با راهنمایی درست می‌توانیم محیطی امن، سالم و غنی برای زندگی آن‌ها فراهم کنیم.</p>
          <a href="/articles" class="rust-btn">مطالعه راهنمای ویژه <span>←</span></a>
        </div>
        <div class="hero-stack">
          <img class="macaw" src="/images/photos/macaw-3.jpg" alt="طوطی ماکائو آبی و طلایی" width="800" height="650" fetchpriority="high" />
          <img class="snake" src="/images/photos/corn-snake-3.jpg" alt="مار کورن اسنیک" width="800" height="520" fetchpriority="high" />
        </div>
      </div>

    <nav class="animal-nav" aria-label="دسته‌بندی حیوانات">
      <a href="/category/reptiles"><span>◉</span> خزندگان</a><a href="/category/birds"><span>◌</span> پرندگان</a>
      <a href="/category/mammals"><span>◈</span> پستانداران کوچک</a><a href="/category/amphibians"><span>⌁</span> دوزیستان</a>
    </nav>

      <div class="guides-panel">
        <div class="panel-head"><div><span>راهنمای نگهداری</span><h2>جدیدترین راهنماها</h2></div><a href="/articles">مشاهده همه</a></div>
        <div class="guide-grid">
          {guides.map((item) => (
            <a href={`/articles/${item.id}`} class="guide-card">
              <div class="guide-image">{item.data.cover ? <img src={item.data.cover} alt={item.data.title} loading="lazy" width="520" height="600" /> : <div class="fallback">✦</div>}</div>
              <div class="guide-body"><h3>{item.data.title}</h3><span>{item.data.category} · {fa(item.data.pubDate)}</span></div>
            </a>
          ))}
        </div>
      </div>

      <aside class="action-stack">
        <section class="consult-card"><span class="line-icon">♧</span><div><small>پاسخ تخصصی و مطمئن</small><h2>مشاوره با دامپزشک</h2><p>عکس، فیلم و توضیحات حیوان خود را ارسال کنید و راهنمایی تخصصی دریافت کنید.</p><a href="/visit">مشاوره با دامپزشک ←</a></div></section>
        <section class="library-card"><div><small>منابع منتخب و معتبر</small><h2>کتابخانه اگزوتیک</h2><p>کتاب‌ها و منابع تخصصی پزشکی و نگهداری حیوانات خاص.</p><a href="/books">مشاهده کتاب‌ها ←</a></div>{featuredBook?.data.cover ? <img src={featuredBook.data.cover} alt={featuredBook.data.title} loading="lazy" width="220" height="300" /> : <div class="book-art">کتاب<br />اگزوتیک</div>}</section>
      </aside>
    </section>
  </div>
</Base>

<style>
  :global(body) { background:#202313; color:#f1e5c9; }
  .magazine-shell{--paper:#ead9b5;--ink:#252919;--gold:#c39a4a;--rust:#b94d1e;width:100%;max-width:1600px;padding:12px 14px 28px}
  .editorial-grid{display:grid;direction:ltr;grid-template-columns:23% 45% 32%;grid-template-rows:430px 72px 330px;grid-template-areas:"news hero hero" "news nav actions" "guides guides actions";overflow:hidden;border:1px solid rgba(211,177,103,.38);border-radius:20px;background:#252a17;box-shadow:0 24px 70px rgba(0,0,0,.34)}
  .editorial-grid>*{direction:rtl}
  .news-rail{grid-area:news;padding:22px 20px;background:linear-gradient(180deg,#282d19,#202412);border-inline-start:1px solid rgba(211,177,103,.3)}
  .rail-title{display:flex;align-items:center;gap:12px;color:#f2dfb8;font-size:20px;font-weight:700;padding-bottom:14px;border-bottom:1px solid rgba(211,177,103,.35)}
  .rail-title i{width:8px;height:8px;border-radius:50%;background:#b94d1e;box-shadow:0 0 0 5px rgba(185,77,30,.16)}
  .rail-list{display:flex;flex-direction:column}.rail-item{display:flex;gap:10px;align-items:center;min-height:72px;padding:4px 0;border-bottom:1px dashed rgba(211,177,103,.28)}.rail-item>span{flex:1;min-width:0}
  .rail-item img{width:96px;height:64px;flex:0 0 96px;border-radius:10px;object-fit:cover}.rail-item b{font-size:12.8px;line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.rail-item small{display:flex;align-items:center;gap:6px;margin-top:3px;color:#bba87e;font-size:10px}.rail-item small em{font-style:normal;color:#e5c47e;padding-inline-end:6px;border-inline-end:1px solid rgba(211,177,103,.35)}
  .text-link{display:inline-flex;margin-top:14px;padding:7px 14px;border:1px solid rgba(211,177,103,.38);border-radius:8px;font-size:12px;color:#e4c98f}
  .editorial-grid>.hero-collage{grid-area:hero;display:grid;grid-template-columns:32% 41% 27%;direction:ltr;position:relative;overflow:hidden;background:var(--paper);color:var(--ink)}
  .hero-collage>*{direction:rtl;min-width:0}.hero-iguana{overflow:hidden;background:#1b2114}.hero-iguana img{width:100%;height:100%;object-fit:cover;object-position:50% center;filter:saturate(.88) brightness(.78) contrast(1.08)}
  .hero-copy{z-index:2;margin-inline:-22px;clip-path:polygon(5% 0,96% 0,100% 12%,96% 24%,100% 38%,96% 51%,100% 66%,96% 81%,100% 100%,2% 100%,0 88%,4% 74%,0 60%,4% 46%,0 31%,4% 16%,0 0);display:flex;flex-direction:column;justify-content:center;padding:36px 48px;position:relative;background:linear-gradient(105deg,#dfc99d,#f0dfbd)}
  .hero-copy:before,.hero-copy:after{content:"";position:absolute;width:82px;height:82px;border:1px solid rgba(65,74,40,.12);border-radius:50%}.hero-copy:before{top:18px;left:38px}.hero-copy:after{bottom:10px;right:35px}
  .kicker{color:#8c602c;font-size:12px;font-weight:700;margin-bottom:10px}.hero-copy h1{font-size:clamp(2rem,3vw,3rem);line-height:1.28;letter-spacing:-.045em}.hero-copy h1 span{white-space:nowrap}.hero-copy p{color:#4f513f;font-size:13px;line-height:1.9;margin:14px 0 18px}.rust-btn{align-self:flex-start;background:var(--rust);color:#fff5dc;padding:10px 17px;border-radius:8px;font-size:13px;font-weight:700;box-shadow:0 10px 25px rgba(130,45,16,.22)}
  .hero-stack{position:relative;overflow:hidden;background:#262b18}.hero-stack img{position:absolute;width:100%;object-fit:cover}.hero-stack .macaw{inset:0 0 auto;height:68%;object-position:54% 35%;filter:saturate(1.05)}.hero-stack .snake{inset:auto 0 0;height:45%;object-position:center;border-top:5px solid #dfc99d}
  .animal-nav{grid-area:nav;display:grid;grid-template-columns:repeat(4,1fr);background:#262b17;border-top:1px solid rgba(211,177,103,.35);border-bottom:1px solid rgba(211,177,103,.35)}.animal-nav a{display:flex;justify-content:center;align-items:center;gap:9px;padding:12px 8px;color:#ead5a8;font-size:13px;font-weight:700;border-inline-start:1px solid rgba(211,177,103,.23);transition:.2s}.animal-nav a:hover{background:#33391f;color:#fff0ca}.animal-nav span{color:var(--gold);font-size:18px}
  .guides-panel{grid-area:guides;padding:22px 20px 24px;min-width:0;background:var(--paper);color:var(--ink)}
  .panel-head{display:flex;align-items:end;justify-content:space-between;gap:18px;margin-bottom:14px}.panel-head span{color:#9b692e;font-size:11px;font-weight:700}.panel-head h2{font-size:24px}.panel-head>a{color:#7e5426;font-size:12px;border-bottom:1px solid}
  .guide-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}.guide-card{height:238px;background:#252a18;color:#f4e7ca;border-radius:13px;overflow:hidden;box-shadow:0 8px 25px rgba(60,43,20,.16);transition:transform .2s}.guide-card:hover{transform:translateY(-4px)}
  .guide-image{height:150px;overflow:hidden;background:#30351f}.guide-image img{width:100%;height:100%;object-fit:cover;transition:transform .4s}.guide-card:hover img{transform:scale(1.05)}.fallback{height:100%;display:grid;place-items:center;font-size:36px}.guide-body{padding:10px 12px}.guide-body h3{font-size:12.5px;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.guide-body span{display:block;color:#c9a765;font-size:9px;margin-top:6px}
  .action-stack{grid-area:actions;padding:14px;background:#242817;border-inline-start:1px solid rgba(211,177,103,.3);display:grid;grid-template-rows:1.35fr 1fr;gap:12px}.consult-card,.library-card{border-radius:14px;overflow:hidden;padding:20px}
  .consult-card{background:linear-gradient(135deg,#087d7a,#176d6e);color:#f5ead2;display:grid;grid-template-columns:64px 1fr;gap:16px;align-items:center}.line-icon{font-size:54px;opacity:.82;border-inline-end:1px dashed rgba(255,255,255,.45)}
  .action-stack small{opacity:.75;font-size:10px}.action-stack h2{font-size:19px;margin:2px 0 6px}.action-stack p{font-size:11px;line-height:1.7;color:inherit;opacity:.84}.action-stack a{display:inline-flex;background:#efe0bd;color:#34301e;padding:7px 12px;border-radius:7px;font-size:11px;font-weight:700;margin-top:10px}
  .library-card{background:linear-gradient(135deg,#ad491f,#c4652e);color:#fff0d2;display:grid;grid-template-columns:1fr 86px;gap:10px;align-items:center}.library-card img{width:80px;height:112px;object-fit:cover;border-radius:4px;transform:rotate(-5deg);box-shadow:7px 8px 0 rgba(68,36,17,.3)}.book-art{background:#28311e;color:#e8d5a5;height:112px;display:grid;place-items:center;text-align:center;border:4px solid #d9ba77;box-shadow:7px 8px 0 rgba(68,36,17,.3);transform:rotate(-4deg)}
  @media(max-width:1100px){.editorial-grid{grid-template-columns:1fr;grid-template-rows:auto;grid-template-areas:"hero" "nav" "guides" "actions" "news"}.hero-collage{height:480px}.news-rail{border:0}.action-stack{grid-template-columns:1fr 1fr;grid-template-rows:260px}.guides-panel{padding:26px 20px}.guide-card{height:245px}}
  @media(max-width:760px){.magazine-shell{padding:10px}.editorial-grid{border-radius:16px}.editorial-grid>.hero-collage{height:auto;display:flex;flex-direction:column}.hero-iguana{display:none}.hero-copy{order:1;margin:0;clip-path:none;padding:38px 25px}.hero-copy h1{font-size:2.25rem}.hero-copy h1 span{white-space:normal}.hero-stack{order:2;height:220px;display:grid;grid-template-columns:1fr 1fr}.hero-stack img{position:static!important;width:100%;height:220px!important}.hero-stack .snake{border-top:0;border-inline-start:5px solid var(--paper)}.animal-nav{grid-template-columns:1fr 1fr}.action-stack{grid-template-columns:1fr;grid-template-rows:auto;padding:14px}.consult-card,.library-card{min-height:210px}.guide-grid{grid-template-columns:1fr 1fr}.guide-card:nth-child(n+5){display:none}.rail-list{display:grid;grid-template-columns:1fr 1fr;gap:0 16px}}
  @media(max-width:480px){.rail-list{grid-template-columns:1fr}.guide-grid{gap:10px}.guide-card{height:220px}.guide-image{height:135px}.animal-nav a{font-size:12px}.consult-card{grid-template-columns:1fr}.line-icon{display:none}.library-card{grid-template-columns:1fr 76px}}
</style>
